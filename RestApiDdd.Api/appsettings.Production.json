{
  "AwsParameterStore": {
    "Enabled": true,
    "Region": "us-east-1",
    "JwtSigningKeyParameterName": "/RestApiDdd/Production/Jwt/SigningKey",
    "DefaultConnectionParameterName": "/RestApiDdd/Production/ConnectionStrings/DefaultConnection"
  },
  "Serilog": {
    "Using": [
      "Serilog.Expressions",
      "AWS.Logger.SeriLog",
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Formatting.Compact"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "RestApiDdd.Api"
    },
    "WriteTo": [
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Region": "us-east-1",
            "LogGroup": "/rest-api-ddd/api",
            "DisableLogGroupCreation": false,
            "NewLogGroupRetentionInDays": 30,
            "LogStreamNamePrefix": "api-",
            "Filter": [
              {
                "Name": "ByExcluding",
                "Args": {
                  "expression": "SourceContext = 'RestApiDdd.Api.Middleware.RequestResponseLoggingMiddleware'"
                }
              }
            ],
            "WriteTo": [
              {
                "Name": "Console",
                "Args": {
                  "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
                }
              },
              {
                "Name": "AWSSeriLog"
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Region": "us-east-1",
            "LogGroup": "/rest-api-ddd/api-requests",
            "DisableLogGroupCreation": false,
            "NewLogGroupRetentionInDays": 30,
            "LogStreamNamePrefix": "requests-",
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "SourceContext = 'RestApiDdd.Api.Middleware.RequestResponseLoggingMiddleware'"
                }
              }
            ],
            "WriteTo": [
              {
                "Name": "AWSSeriLog"
              }
            ]
          }
        }
      }
    ]
  }
}
