{
  "AwsParameterStore": {
    "Enabled": true,
    "Region": "us-east-1",
    "JwtSigningKeyParameterName": "/RestApiDdd/Production/Jwt/SigningKey",
    "DefaultConnectionParameterName": "/RestApiDdd/Production/ConnectionStrings/DefaultConnection"
  },
  "ProductionCloudWatchLogs": {
    "Region": "us-east-1",
    "ApiLogGroup": "/rest-api-ddd/api",
    "ApiLogStreamNamePrefix": "api-",
    "RequestLogGroup": "/rest-api-ddd/api-requests",
    "RequestLogStreamNamePrefix": "requests-",
    "DisableLogGroupCreation": false,
    "NewLogGroupRetentionInDays": 30
  },
  "Serilog": {
    "Using": [
      "Serilog.Expressions",
      "AWS.Logger.SeriLog",
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Formatting.Compact"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "RestApiDdd.Api"
    }
  }
}
